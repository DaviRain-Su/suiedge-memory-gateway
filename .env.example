# SuiEdge Memory Gateway — environment variables.
# Copy to .env.testnet (or .env.local for Next.js) and fill in.
# All variables have safe defaults; only SUI_PACKAGE_ID + SUI_PRIVATE_KEY
# are required to go live.

# Network: testnet | mainnet | devnet. Default testnet.
NEXT_PUBLIC_SUI_NETWORK=testnet

# Required for live mode. Output of `sui client publish` on the move/ package.
SUI_PACKAGE_ID=

# Bech32 private key (suiprivkey1...). The server-side signer. Acts as the
# AgentSpace owner in the MVP — in production each user would sign with their
# own wallet and the gateway would forward PTBs to a sponsored endpoint.
SUI_PRIVATE_KEY=

# Gas budget per PTB in MIST. 50_000_000 = 0.05 SUI per PTB.
SUI_GAS_BUDGET=50000000

# Walrus testnet. Leave blank to fall back to the published defaults.
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# Epochs to store blobs. Walrus testnet = 1 epoch ~ 1 day; mainnet ~ 14 days.
WALRUS_EPOCHS=1

# Switch: 1 enables LiveSuiClient (real testnet PTBs). 0 = MockSuiClient.
SUI_CLIENT_LIVE=0

# Dev affordance: when 1, X-Sui-Signature: stub is accepted without crypto verify.
# Only set this for local dev / demo videos. Never in production.
AUTH_STUB_PASS=0

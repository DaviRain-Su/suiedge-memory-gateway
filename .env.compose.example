# Copy to .env.compose and fill in the secrets for `docker compose up`.
# Anything left empty is replaced by the default in docker-compose.yml.

# === Sui ===
# Set SUI_CLIENT_LIVE=1 to talk to real Sui testnet. 0 = offline mock.
SUI_CLIENT_LIVE=0
# SUI_PACKAGE_ID is the published Move package id from `pnpm run publish:testnet`.
SUI_PACKAGE_ID=
# SUI_PRIVATE_KEY is a bech32 suiprivkey1... string. NEVER commit this.
SUI_PRIVATE_KEY=
SUI_GAS_BUDGET=50000000

# === Walrus ===
# Public Walrus testnet by default. Override for mainnet.
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_EPOCHS=1

# === Auth ===
# 1 lets demos skip wallet-signature verification. 0 = real wallet required.
AUTH_STUB_PASS=1

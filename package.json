{
  "name": "suiedge-memory-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:move": "cd move && sui move test",
    "test:live": "SUI_CLIENT_LIVE=1 vitest run tests/gateway/live",
    "test:sdk": "node --experimental-strip-types --test sdks/client-sdk/tests/*.test.ts sdks/ai-sdk/tests/*.test.ts sdks/langchain/tests/*.test.ts",
    "db:migrate": "node --experimental-strip-types scripts/migrate.ts",
    "mcp": "node --experimental-strip-types src/mcp/server.ts",
    "publish:testnet": "bash scripts/publish-testnet.sh",
    "dev:live": "set -a && . ./.env.testnet && set +a && SUI_CLIENT_LIVE=1 next dev -p 3000",
    "start:live": "set -a && . ./.env.testnet && set +a && SUI_CLIENT_LIVE=1 next start -p 3000"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "@mysten/dapp-kit": "latest",
    "@mysten/sui": "latest",
    "@tanstack/react-query": "^5.101.0",
    "better-sqlite3": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/better-sqlite3": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "playwright": "^1.60.0",
    "typescript": "latest",
    "vitest": "latest"
  }
}
